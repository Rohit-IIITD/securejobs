# ─────────────────────────────────────────────
#  Copy this file to .env and fill every value.
#  Never commit .env to git.
# ─────────────────────────────────────────────

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_32_PLUS_RANDOM_CHARS

# AES-256-GCM resume encryption key — must be exactly 32 ASCII bytes
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"  (gives 32 hex chars)
AES_KEY=0123456789abcdef0123456789abcdef

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobportal_db
DB_USER=jobportal_user
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# Gmail SMTP (use an App Password, not your real Gmail password)
# How to create one: Google Account → Security → 2-Step Verification → App passwords
SMTP_EMAIL=you@gmail.com
SMTP_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Admin seed account (created automatically on first startup)
ADMIN_EMAIL=admin@portal.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
